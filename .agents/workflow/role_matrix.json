{
  "version": 1,
  "roles": {
    "ambiguity_gatekeeper": {
      "artifacts_required": [
        ".agents/workflow/runs/<YYYY-MM-DD>_<slug>_focus_card.md"
      ],
      "gates": [
        {
          "script": ".agents/scripts/gates/ambiguity_gate.py",
          "args": [
            "--intent",
            "{intent_text}"
          ]
        },
        {
          "script": ".agents/scripts/gates/focus_card_gate.py",
          "args": [
            "--file",
            ".agents/workflow/runs/<YYYY-MM-DD>_<slug>_focus_card.md"
          ]
        }
      ]
    },
    "focus_guard": {
      "artifacts_required": [
        ".agents/workflow/runs/<YYYY-MM-DD>_<slug>_focus_card.md"
      ],
      "gates": [
        {
          "script": ".agents/scripts/gates/scope_guard.py",
          "args": [
            "--focus-card",
            ".agents/workflow/runs/<YYYY-MM-DD>_<slug>_focus_card.md",
            "--files",
            "{changed_files}"
          ]
        }
      ]
    },
    "architecture_curator": {
      "gates": [
        {
          "script": ".agents/scripts/gates/writeback_gate.py",
          "args": [
            "--topic",
            "{topic}",
            "--date",
            "{date}",
            "--require",
            "architecture"
          ]
        }
      ]
    },
    "security_sentinel": {
      "gates": [
        {
          "script": ".agents/scripts/gates/secrets_linter.py",
          "args": [
            "--paths",
            "src/main/resources/**/*.yml",
            "src/main/resources/**/*.yaml",
            "src/main/resources/**/*.properties",
            ".agents/**/*.md"
          ]
        }
      ]
    },
    "documentation_curator": {
      "gates": [
        {
          "script": ".agents/scripts/gates/delivery_capsule_gate.py",
          "args": [
            "--file",
            "{delivery_file}"
          ]
        },
        {
          "script": ".agents/scripts/wiki/wiki_linter.py",
          "args": []
        }
      ]
    },
    "skill_graph_curator": {
      "gates": [
        {
          "script": ".agents/scripts/gates/skill_index_linter.py",
          "args": [
            "--index",
            ".agents/skills/trae-skill-index/SKILL.md",
            "--skills-dir",
            ".agents/skills",
            "--fail-on-missing"
          ]
        }
      ]
    },
    "requirement_engineer": {
      "gates": [
        {
          "script": ".agents/scripts/gates/ambiguity_gate.py",
          "args": [
            "--require",
            "<YYYY-MM-DD>_<slug>_explore_report.md"
          ]
        }
      ]
    },
    "system_architect": {
      "gates": [
        {
          "script": ".agents/scripts/gates/openspec_gate.py",
          "args": [
            "--require",
            ".agents/workflow/runs/<YYYY-MM-DD>_<slug>_openspec.md"
          ]
        }
      ]
    },
    "lead_engineer": {
      "gates": [
        {
          "script": ".agents/scripts/gates/scope_guard.py",
          "args": [
            "--focus-card",
            ".agents/workflow/runs/<YYYY-MM-DD>_<slug>_focus_card.md",
            "--files",
            "{changed_files}"
          ]
        }
      ]
    },
    "code_reviewer": {
      "gates": [
        {
          "script": ".agents/scripts/gates/linter.py",
          "args": [
            "--strict"
          ]
        }
      ]
    },
    "librarian": {
      "gates": [
        {
          "script": ".agents/scripts/wiki/wiki_linter.py",
          "args": []
        }
      ]
    },
    "knowledge_extractor": {
      "gates": [
        {
          "script": ".agents/scripts/gates/writeback_gate.py",
          "args": [
            "--topic",
            "{topic}",
            "--date",
            "{date}",
            "--require",
            "domain,api,rules"
          ]
        }
      ]
    }
  },
  "mounts": [
    {
      "intent": "Change",
      "profile": "PATCH",
      "phase": "Explorer",
      "roles": [
        "ambiguity_gatekeeper",
        "focus_guard"
      ]
    },
    {
      "intent": "Change",
      "profile": "PATCH",
      "phase": "Implement",
      "roles": [
        "focus_guard",
        "security_sentinel"
      ]
    },
    {
      "intent": "Change",
      "profile": "PATCH",
      "phase": "QA",
      "roles": [
        "documentation_curator"
      ]
    },
    {
      "intent": "Change",
      "profile": "PATCH",
      "phase": "Archive",
      "roles": [
        "knowledge_extractor",
        "documentation_curator",
        "skill_graph_curator"
      ]
    },
    {
      "intent": "Change",
      "profile": "STANDARD",
      "phase": "Explorer",
      "roles": [
        "ambiguity_gatekeeper",
        "requirement_engineer",
        "focus_guard"
      ]
    },
    {
      "intent": "Change",
      "profile": "STANDARD",
      "phase": "Propose",
      "roles": [
        "system_architect"
      ]
    },
    {
      "intent": "Change",
      "profile": "STANDARD",
      "phase": "Implement",
      "roles": [
        "lead_engineer",
        "focus_guard",
        "security_sentinel"
      ]
    },
    {
      "intent": "Change",
      "profile": "STANDARD",
      "phase": "QA",
      "roles": [
        "code_reviewer",
        "documentation_curator"
      ]
    },
    {
      "intent": "Change",
      "profile": "STANDARD",
      "phase": "Archive",
      "roles": [
        "knowledge_extractor",
        "documentation_curator",
        "skill_graph_curator",
        "librarian"
      ]
    },
    {
      "intent": "Workflow",
      "profile": "PATCH",
      "phase": "Explorer",
      "roles": [
        "ambiguity_gatekeeper",
        "focus_guard"
      ]
    },
    {
      "intent": "Workflow",
      "profile": "PATCH",
      "phase": "Implement",
      "roles": [
        "focus_guard",
        "security_sentinel"
      ]
    },
    {
      "intent": "Workflow",
      "profile": "PATCH",
      "phase": "Archive",
      "roles": [
        "architecture_curator",
        "documentation_curator",
        "skill_graph_curator"
      ]
    },
    {
      "intent": "Workflow",
      "profile": "STANDARD",
      "phase": "Explorer",
      "roles": [
        "ambiguity_gatekeeper",
        "focus_guard"
      ]
    },
    {
      "intent": "Workflow",
      "profile": "STANDARD",
      "phase": "Implement",
      "roles": [
        "focus_guard",
        "security_sentinel"
      ]
    },
    {
      "intent": "Workflow",
      "profile": "STANDARD",
      "phase": "Archive",
      "roles": [
        "architecture_curator",
        "documentation_curator",
        "skill_graph_curator"
      ]
    }
  ]
}